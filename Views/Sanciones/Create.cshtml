@model ClubId.Models.ViewModels.SancionCreacionViewModel

@{
// ¡Armemos el Nuevo Boletín de Sanciones!
ViewData["Title"] = "¡Armemos el Nuevo Boletín de Sanciones!";
}

@* NOTA: Este código asume que tienes acceso a jQuery y Bootstrap.
Usamos Select2 para la búsqueda avanzada de jugadores. *@

<div class="container py-4">
<div class="card shadow-lg">
<div class="card-header bg-primary text-white">
<h3 class="mb-0">¡Armemos el Nuevo Boletín de Sanciones!</h3>
</div>
<div class="card-body">

@* <form asp-action="Create" method="post" enctype="multipart/form-data"> *@
    <form  method="post" enctype="multipart/form-data" >
     @*    con esto edita *@
     <input type="hidden" asp-for="IdSanciones" />

        <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

        @* {{-- Sección de Encabezado del Boletín --}} *@
        <h4 class="text-primary border-bottom pb-2 mb-4">Datos Principales del Boletín</h4>
        <div class="row">
            <div class="col-md-2 mb-3" style="width: 20%">
                <label asp-for="FechaBoletin" class="form-label">Fecha (¿Cuándo es esto?)</label>
                <input asp-for="FechaBoletin" type="date" class="form-control" />
                <span asp-validation-for="FechaBoletin" class="text-danger"></span>
            </div>
            <div class="col-md-2 mb-2" style="width: 15%">
                <label asp-for="NroFecha" class="form-label">Nro de Fecha</label>
                <input type="number" asp-for="NroFecha" class="form-control"  min="1" max="99" required />
            </div>

                 <div  class="col-md-2 mb-3"  style="width: 20%">
                        <label asp-for="IdCategoria" class="form-label"></label>
                        <select asp-for="IdCategoria" class ="form-select" asp-items="ViewBag.IdCategoria">
                              <option value="">-- Categoría --</option> 
                        </select>
                         <span asp-validation-for="IdCategoria" class="text-danger"></span>
                    </div>
        <div class="col-md-5 mb-4">
                <label asp-for="Comunicado" class="form-label">COMUNICADO GENERAL</label>
                <textarea asp-for="Comunicado" class="form-control" rows="3"></textarea>
                <span asp-validation-for="Comunicado" class="text-danger"></span>
            </div>
        </div>

        <hr class="my-4" />

        @* {{-- Sección de Gestión de Jugadores --}} *@
        <h4 class="text-primary border-bottom pb-2 mb-4">Jugadores que van con Sanción</h4>

        <div class="row g-3 align-items-end mb-4 p-3 border rounded bg-light">            
            <div class="col-md-4">
                <label for="JugadorSearch" class="form-label">Buscá y Elegí al Jugador</label>
                <select id="JugadorSearch" class="form-select w-100" style="width: 100%"></select>
            </div>        
            <div class="col-md-4">
                <label for="EquipoSearch" class="form-label">Buscá y Elegí al Equipo</label>
                <select id="EquipoSearch" class="form-select w-100" style="width: 100%"></select>
        </div> 
            <div class="col-md-2">
                <button type="button" id="btnAddJugador" class="btn btn-success w-100">¡Sumar!</button>
            </div>
            <div class="col-8">
                 <label for="txtMotivo" class="form-label"> Informe ARBITRO (¡El Por qué!)</label>
                <textarea id="txtMotivo" class="form-control" rows="2"  placeholder="Contá bien la falta, el informe, o lo que pasó." ></textarea>
            </div>
             <div class="col-4">
                 <label for="txtArticulo" class="form-label">Sancion y Articulos Aplicados</label>
                <textarea id="txtArticulo" class="form-control" rows="2"  placeholder="Que articulos se aplicaron en la sancion." ></textarea>
            </div>
        </div>

        @* {{-- Tabla de Jugadores Sancionados --}} *@
        <div class="table-responsive">
            <table class="table table-striped table-hover align-middle" id="jugadoresTable">
                <thead class="table-dark">
                    <tr>
                        <th>DNI</th>
                        <th>Nombre del Jugador</th>
                        <th>Equipo</th>
                        <th>Cant. Partidos</th>
                        <th>Motivo del Informe</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @* Los jugadores seleccionados se añaden aquí con JavaScript,
                        pero si la validación del POST falla, MVC puede restaurar la lista
                        usando el bucle @if/for. *@
                    @if (Model.JugadoresSancionados.Any())
                    {
                        for(int i = 0; i < Model.JugadoresSancionados.Count; i++)
                        {
                            var item = Model.JugadoresSancionados[i];
                            <tr data-id="@item.IdJugador"> 
                                <td>@item.Dni</td>
                                <td>@item.NombreCompleto</td>
                                <td>@item.NombreEq</td>
                                <td>                                    
                                    <input type="text" name="JugadoresSancionados[@i].CantidadPartidos" value="@item.CantidadPartidos" class="form-control form-control-sm input-articulo"  style="width: 140px;"  />
                                    <input type="hidden" name="JugadoresSancionados[@i].IdSanciones" value="@item.IdSanciones" />
                                    <input type="hidden" name="JugadoresSancionados[@i].IdJugador" value="@item.IdJugador" />
                                     <input type="hidden" name="JugadoresSancionados[@i].Nombre" value="@item.Nombre" />
                                    <input type="hidden" name="JugadoresSancionados[@i].Apellido" value="@item.Apellido" /> 
                                    <input type="hidden" name="JugadoresSancionados[@i].Dni" value="@item.Dni" />
                                    <input type="hidden" name="JugadoresSancionados[@i].IdEquipo" value="@item.IdEquipo" />                                     
                                     <input type="hidden" name="JugadoresSancionados[@i].NombreEq" value="@item.NombreEq" />  
                                    <input type="hidden" name="JugadoresSancionados[@i].NombreCompleto" value="@item.NombreCompleto" />                                    
                                
                                </td>
                                <td>
                                    <textarea name="JugadoresSancionados[@i].MotivoEspecifico" class="form-control form-control-sm input-motivo" rows="1" >@item.MotivoEspecifico</textarea>
                                </td>
                                <td>
                                    <button type="button" class="btn btn-sm btn-danger btn-remove ">Sacar</button>                                  
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>

        <div class="text-end mt-4">
            <a asp-action="Index" class="btn btn-secondary">Mejor no (Cancelar)</a>
            <button type="submit" class="btn btn-primary">¡Listo, Guardar Boletín!</button>
        </div>
    </form>
</div>


</div>

</div>

@section Scripts {
@{await Html.RenderPartialAsync("_ValidationScriptsPartial");}

@* <script src="https://www.google.com/search?q=https://cdnjs.cloudflare.com/ajax/libs/select2/4.1.0-rc.0/js/select2.full.min.js"></script>

<link href="https://www.google.com/search?q=https://cdnjs.cloudflare.com/ajax/libs/select2/4.1.0-rc.0/css/select2.min.css" rel="stylesheet" /> *@
<script src="https://cdnjs.cloudflare.com/ajax/libs/select2/4.1.0-rc.0/js/select2.full.min.js"></script>
<link href="https://cdnjs.cloudflare.com/ajax/libs/select2/4.1.0-rc.0/css/select2.min.css" rel="stylesheet" />

<script>
// Contador global para asegurar índices únicos para el Model Binder de MVC
var jugadorIndex = @(Model.JugadoresSancionados.Any() ? Model.JugadoresSancionados.Count : 0);

// Mensaje de alerta personalizado para no usar alert()
function showCustomAlert(message) {
    // Reemplaza esto con un modal o una notificación de Toastr en una aplicación real.
    alert(message);
}

$(document).ready(function () {
    // 1. Inicializar Select2 para la búsqueda AJAX
    $('#JugadorSearch').select2({
        placeholder: "Buscá por Apellido, Nombre o DNI... ¡Vamos!",
        minimumInputLength: 3, // Empezar a buscar después de 3 caracteres
       // theme: 'bootstrap-5', // Descomentar si usas el tema de Bootstrap 5 para Select2
        ajax: {
            url: '@Url.Action("BuscarJugadores", "Sanciones")',dataType: 'json',
            delay: 250,
            data: function (params) {
                return {
                    term: params.term
                };
            },
            processResults: function (data) {
                return {
                    results: data.results // El controlador devuelve { results: [...] }
                };
            },
            cache: true
        }
    });

        $('#EquipoSearch').select2({
        placeholder: "Escribí el nombre del equipo...",
        minimumInputLength: 2, // Buscamos a partir de 2 letras
        ajax: {
            url: '@Url.Action("BuscarEquipos", "Sanciones")', // Asegurate que el nombre del Action coincida
            dataType: 'json',
            delay: 250,            
            data: function (params) {
                return {
                    term: params.term // El texto que el usuario escribe                   
                };
            },
            processResults: function (data) {
                return {
                    results: data.results
                };
            },
            cache: true
        }
    });      

    // 2. Función para recalcular los índices de la tabla (CRUCIAL para el Model Binder de ASP.NET Core)
    function reIndexTable() {
        $('#jugadoresTable tbody tr').each(function (index) {
            // Actualiza el índice en el nombre de todos los inputs para que MVC los reconozca como una lista
            $(this).find('input, textarea').each(function () {
                var name = $(this).attr('name');
                if (name) {
                    // Usamos una expresión regular para reemplazar el índice actual por el nuevo
                    $(this).attr('name', name.replace(/\[\d+\]/g, '[' + index + ']'));
                }
            });
        });
        // Sincroniza el contador global con la cantidad actual de filas
        jugadorIndex = $('#jugadoresTable tbody tr').length;
    }

    // 3. Añadir jugador a la lista
    $('#btnAddJugador').click(function () {
        var selectData = $('#JugadorSearch').select2('data')[0];
        var idJugador = selectData ? selectData.id : null;
        // El campo 'nombreCompleto' y 'dni' vienen del resultado JSON del controlador
        var nombreCompleto = selectData ? selectData.nombreCompleto : null;
        var dni = selectData ? selectData.dni : null; 
        var articulos = $('#txtArticulo').val();
       // var partidos = $('#txtPartidos').val();
        var motivo = $('#txtMotivo').val();          
        
        var nombre = selectData ? selectData.nombre : null;
        var apellido = selectData ? selectData.apellido : null;            

        var dataEquipo = $('#EquipoSearch').select2('data')[0];
        var NombreEquipo = dataEquipo ? dataEquipo.nombreEquipo : null;
        var idEquipo  = dataEquipo ?  dataEquipo.id : null ;

        console.log(articulos);
         console.log(motivo);
          console.log(selectData);

        if (!idJugador ||  !motivo || !NombreEquipo) {
            showCustomAlert('¡Ojo! Tenés que elegir un jugador, ponerle los partidos y contar el motivo.');            
            return;
        }

        // Evitar duplicados
        if ($('#jugadoresTable tbody tr[data-id="' + idJugador + '"]').length > 0) {
            showCustomAlert('¡Uy! Este jugador ya está en la lista del boletín.');
            return;
        }
        
        // Sanitización básica para HTML
        motivo = motivo.replace(/</g, "=<").replace(/>/g, "=>");

        // Construcción de la fila de la tabla
        var newRow = `
            <tr data-id="${idJugador}">
                <td>${dni}</td>
                <td>${nombreCompleto}</td>
                <td style="width: 250px;">${NombreEquipo}</td>
                <td>                
                    @* <input type="text" name="JugadoresSancionados[${jugadorIndex}].CantidadPartidos" value="${articulos}" class="form-control form-control-sm input-partidos" style="width: 120px;" required /> *@
                    <input type="text" name="JugadoresSancionados[${jugadorIndex}].CantidadPartidos" value="${articulos}" class="form-control form-control-sm input-articulo" style="width: 120px;"  />
                    <input type="hidden" name="JugadoresSancionados[${jugadorIndex}].IdJugador" value="${idJugador}" />      
                     <input type="hidden" name="JugadoresSancionados[${jugadorIndex}].Nombre" value="${nombre}" /> 
                     <input type="hidden" name="JugadoresSancionados[${jugadorIndex}].Apellido" value="${apellido}" /> 
                                         
                    <input type="hidden" name="JugadoresSancionados[${jugadorIndex}].Dni" value="${dni}" />
                    <input type="hidden" name="JugadoresSancionados[${jugadorIndex}].NombreCompleto" value="${nombreCompleto}" />
                     <input type="hidden" name="JugadoresSancionados[${jugadorIndex}].IdEquipo" value="${idEquipo}" />  
                    <input type="hidden" name="JugadoresSancionados[${jugadorIndex}].NombreEq" value="${NombreEquipo}" />                    
                </td>
                <td>
                    <textarea name="JugadoresSancionados[${jugadorIndex}].MotivoEspecifico" class="form-control form-control-sm input-motivo" rows="1" >${motivo}</textarea>
                </td>
                 <td>                         
                         <button type="button" class="btn btn-sm btn-danger btn-remove">Sacar</button>                                  
                </td>
            </tr>`;

        $('#jugadoresTable tbody').append(newRow);
        jugadorIndex++;

        // Limpiar campos después de añadir
        $('#JugadorSearch').val(null).trigger('change');
        $('#txtArticulo').val('');
        $('#txtMotivo').val('');
    });

    // 4. Modificar o Eliminar jugador de la lista
    $('#jugadoresTable').on('click', '.btn-remove', function () {
        // Eliminar la fila
        $(this).closest('tr').remove();
        
        // Reindexar la tabla después de eliminar
        reIndexTable();
    });

    // Asegurar que la tabla esté indexada correctamente al cargar si hay datos de restauración
    reIndexTable();
});

</script>

}