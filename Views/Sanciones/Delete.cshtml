@using ClubId.Data
@using Microsoft.AspNetCore.Mvc.Filters
@using Microsoft.EntityFrameworkCore
@using Microsoft.AspNetCore.Mvc.Rendering;
@using ClubId.Services;

@model ClubId.Models.ViewModels.BoletinSancionesViewModel

@{
    ViewData["Title"] = "Eliminar Sanción";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-lg border-0">
                <div class="card-header bg-danger text-white text-center py-3">
                    <h4 class="mb-0"><i class="bi bi-exclamation-triangle me-2"></i>¿Eliminar este registro?</h4>
                </div>
                <div class="card-body p-4">
                    <p class="text-muted text-center">Esta acción no se puede deshacer. Por favor, confirma los datos del boletín:</p>
                    
                    <ul class="list-group list-group-flush mb-4">
                        <li class="list-group-item d-flex justify-content-between">
                            <strong>Fecha:</strong> <span>@Model.FechaBoletin.ToString("dd/MM/yyyy")</span>
                        </li>
                        <li class="list-group-item d-flex justify-content-between">
                            <strong>Categoría:</strong> <span>@Model.NombreCategoria</span>
                        </li>
                        <li class="list-group-item">
                            <strong>Comunicado:</strong>
                            <p class="small text-muted mt-1">@Model.Comunicado</p>
                        </li>
                    </ul>

                    <form asp-action="Delete">
                        <input type="hidden" asp-for="IdSanciones" />
                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-danger fw-bold">
                                <i class="bi bi-trash"></i> Confirmar Eliminación
                            </button>
                            <a asp-action="Index" class="btn btn-outline-secondary">Cancelar y volver</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>