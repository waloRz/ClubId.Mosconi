@model ClubId.Models.ViewModels.ReporteSancionadosViewModel

<div class="container mt-4">
    <div class="card shadow border-0 mb-4">
        <div class="card-header bg-primary text-white">
            <h4 class="mb-0"><i class="bi bi-filter-square me-2"></i>Filtro de Reporte de Sancionados</h4>
        </div>
        <div class="card-body">
            <form asp-action="Sancionados" method="get" class="row g-3 align-items-end">
                <div class="col-md-3">
                    <label class="form-label fw-bold">Desde</label>
                    <input type="date" name="desde" class="form-control"
                           value="@Model.FechaDesde.ToString("yyyy-MM-dd")" />
                </div>
                <div class="col-md-3">
                    <label class="form-label fw-bold">Hasta</label>
                    <input type="date" name="hasta" class="form-control"
                           value="@Model.FechaHasta.ToString("yyyy-MM-dd")" />
                </div>
                <div class="col-md-3">
                    <label class="form-label fw-bold">Categoría</label>
                    <select name="idCategoria" class="form-select" asp-items="ViewBag.IdCategoria">
                        <option value="">-- Seleccione --</option>
                    </select>
                </div>
                <div class="col-md-3 d-flex gap-2">
                    <button type="submit" class="btn btn-primary w-100">
                        <i class="bi bi-search"></i> Buscar
                    </button>
                    @if (Model.Resultados.Any())
                    {
                        <a asp-action="GenerarReporteSancionados" asp-route-desde="@Model.FechaDesde.ToString("yyyy-MM-dd")"
                               asp-route-hasta="@Model.FechaHasta.ToString("yyyy-MM-dd")"
                               asp-route-idCategoria="@Model.IdCategoria" target="_blank" class="btn btn-danger w-100">
                            <i class="bi bi-file-pdf"></i> PDF
                        </a>
                    }
                </div>
            </form>
        </div>
    </div>

    @if (Model.Resultados.Any())
    {

        <div class="row mb-4">
            <div class="col-md-8 mx-auto">
                <div class="card shadow border-0">
                    <div class="card-header bg-light">
                        <h5 class="mb-0 text-center"><i class="bi bi-graph-up me-2"></i>Sanciones por Equipo</h5>
                    </div>
                    <div class="card-body">
                        <canvas id="graficoSanciones" style="max-height: 300px;"></canvas>
                    </div>
                </div>
            </div>
        </div>

        <div class="card shadow border-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-dark">
                        <tr>
                            <th>EQUIPO</th>
                            <th>NOMBRE Y APELLIDO</th>
                            <th class="text-center">CARNET</th>
                            <th class="text-center">RONDA / FECHA </th>
                            <th>SANCION</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.Resultados)
                        {
                            <tr>
                                <td class="fw-bold">@item.Equipo</td>
                                <td class="text-uppercase">@item.NombreCompleto</td>
                                <td class="text-center">@item.Carnet</td>
                                <td class="text-center">F @item.NroFecha – @item.FechaBoletin</td>
                                <td class="text-uppercase small">@item.SancionTexto</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
    else if (Context.Request.Query.Count > 0)
    {
        <div class="alert alert-info text-center shadow-sm">
            <i class="bi bi-info-circle me-2"></i> No se encontraron sanciones en el rango seleccionado.
        </div>
    }
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <script>
        document.addEventListener("DOMContentLoaded", function () {
        const ctx = document.getElementById('graficoSanciones').getContext('2d');

        const etiquetas = @Html.Raw(Json.Serialize(Model.DatosGrafico.Select(x => x.Etiqueta)));
        const valores = @Html.Raw(Json.Serialize(Model.DatosGrafico.Select(x => x.Valor)));

        // 🎨 Lógica de Color Condicional
        // Si el valor es > 5, usamos Rojo. Si no, usamos el Azul estándar.
        const coloresFondo = valores.map(v => v > 5
        ? 'rgba(255, 99, 132, 0.7)'  // Rojo suave
        : 'rgba(54, 162, 235, 0.6)'  // Azul suave
        );

        const coloresBorde = valores.map(v => v > 5
        ? 'rgba(255, 99, 132, 1)'    // Rojo fuerte
        : 'rgba(54, 162, 235, 1)'    // Azul fuerte
        );

        new Chart(ctx, {
        type: 'bar',
        data: {
        labels: etiquetas,
        datasets: [{
        label: 'Cantidad de Sanciones',
        data: valores,
        backgroundColor: coloresFondo, // Usamos el arreglo dinámico
        borderColor: coloresBorde,     // Usamos el arreglo dinámico
        borderWidth: 1
        }]
        },
        options: {
        responsive: true,
        maintainAspectRatio: false,
        scales: {
        y: {
        beginAtZero: true,
        ticks: {
        stepSize: 1,
        font: { weight: 'bold' }
        }
        },
        x: {
        ticks: { font: { size: 11 } }
        }
        },
        plugins: {
        legend: { display: false },
        tooltip: {
        callbacks: {
        label: function (context) {
        let label = context.dataset.label || '';
        if (context.parsed.y > 5) {
        return label + ': ' + context.parsed.y + ' (CRÍTICO)';
        }
        return label + ': ' + context.parsed.y;
        }
        }
        }
        }
        }
        });
        });
    </script>
}