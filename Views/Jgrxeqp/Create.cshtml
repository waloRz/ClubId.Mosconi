@using ClubId.Data
@using Microsoft.AspNetCore.Mvc.Filters
@using Microsoft.EntityFrameworkCore
@model ClubId.Models.ViewModels.CrearJugadorViewModel

@{
    ViewData["Title"] = "Nuevo Jugador";
}

<div class="container py-4">
    <h2 class="mb-4 text-success">
        <i class="bi bi-person-plus-fill me-2"></i> Alta de Nuevo Jugador
    </h2>

    <form asp-action="Create" method="post" enctype="multipart/form-data" class="mt-3">
        
        <div class="row g-4">
            <div class="col-lg-6">
                <div class="card shadow-sm h-100 border-0">
                    <div class="card-header bg-success text-white">
                        <h5 class="mb-0"><i class="bi bi-person-vcard"></i> Información Personal</h5>
                    </div>
                    <div class="card-body bg-light bg-opacity-10">
                        <div class="row g-3">
                            
                            <div class="col-md-6">
                                <label asp-for="Nombre" class="form-label fw-semibold"></label>
                                <input asp-for="Nombre" class="form-control" placeholder="Ej: Lionel" />
                                <span asp-validation-for="Nombre" class="text-danger"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="Apellido" class="form-label fw-semibold"></label>
                                <input asp-for="Apellido" class="form-control" placeholder="Ej: Messi" />
                                <span asp-validation-for="Apellido" class="text-danger"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="Dni" class="form-label fw-semibold"></label>
                                <div class="input-group">
                                    <span class="input-group-text"><i class="bi bi-postcard"></i></span>
                                    <input asp-for="Dni" class="form-control" id="DniInput" 
                                           oninput="formatAndValidateDni(this)" maxlength="10" 
                                           placeholder="XX.XXX.XXX" />
                                </div>
                                <span asp-validation-for="Dni" class="text-danger"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="FechaNac" class="form-label fw-semibold">Fecha Nacimiento</label>
                                <input asp-for="FechaNac" class="form-control" type="date" />
                                <span asp-validation-for="FechaNac" class="text-danger"></span>
                            </div>
                            
                            <div class="col-12 mt-3 pt-3 border-top">
                                <div class="form-check form-switch p-3 bg-white border rounded">
                                    <input class="form-check-input ms-0 me-3" type="checkbox" asp-for="Activo" role="switch" id="ActivoSwitch" checked />
                                    <label class="form-check-label fw-bold" for="ActivoSwitch">
                                        ¿Jugador Activo?
                                        <small class="d-block text-muted fw-normal">Habilita al jugador inmediatamente.</small>
                                    </label>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-6">
                <div class="card shadow-sm h-100 border-0">
                    <div class="card-header bg-secondary text-white">
                        <h5 class="mb-0"><i class="bi bi-trophy"></i> Afiliación y Fichaje</h5>
                    </div>
                    <div class="card-body">
                        <div class="row g-3">
                            
                            <div class="col-md-6">
                                <label asp-for="IdCategoria" class="form-label fw-semibold">Categoría</label>
                                <select asp-for="IdCategoria" class="form-select" asp-items="@Model.ListaCategoria">
                                    <option value="">-- Seleccionar --</option>
                                </select>
                                <span asp-validation-for="IdCategoria" class="text-danger"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="IdEquipo" class="form-label fw-semibold">Equipo</label>
                                <select asp-for="IdEquipo" class="form-select" asp-items="@Model.ListaEquipos">
                                    <option value="">-- Primero elija Categoría --</option>
                                </select>
                                <span asp-validation-for="IdEquipo" class="text-danger"></span>
                            </div>

                            <div class="col-12">
                                <label asp-for="FechaRecibo" class="form-label fw-semibold">Fecha de Fichaje / Recibo</label>
                                <input asp-for="FechaRecibo" class="form-control" type="date" value="@DateTime.Now.ToString("yyyy-MM-dd")" />
                            </div>

                            <div class="col-12 mt-4">
                                <div class="p-3 border border-2 border-dashed rounded text-center bg-light">
                                    <label class="form-label fw-bold text-secondary mb-3">
                                        <i class="bi bi-camera fs-3 d-block mb-1"></i>
                                        Foto del Jugador (Opcional)
                                    </label>
                                    <input type="file" name="photo" class="form-control" accept="image/*" />
                                    <small class="text-muted mt-2 d-block">Formatos: JPG, PNG, JPEG</small>
                                </div>
                            </div>

                        </div>
                    </div>
                </div>
            </div>

            <div class="col-12 mt-4 d-flex justify-content-end gap-2">
                <a asp-action="Index" class="btn btn-secondary btn-lg px-4">
                    Cancelar
                </a>
                <button class="btn btn-success btn-lg px-5" type="submit">
                    <i class="bi bi-check-lg"></i> Guardar Jugador
                </button>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}

    <script>
        // Función para aplicar el formato del DNI
        function formatAndValidateDni(input) {
            let dniValue = input.value.replace(/\D/g, '');
            let formattedDni = '';
            
            if (dniValue.length > 0) formattedDni += dniValue.substring(0, 2);
            if (dniValue.length > 2) formattedDni += '.' + dniValue.substring(2, 5);
            if (dniValue.length > 5) formattedDni += '.' + dniValue.substring(5, 8);
            if (formattedDni.length > 10) formattedDni = formattedDni.substring(0, 10);

            input.value = formattedDni;
        }

        // --- LÓGICA DE CASCADA DE DROPDOWNS ---
        $(document).ready(function () {
            const categoriaSelect = $('#IdCategoria');
            const equipoSelect = $('#IdEquipo');

            categoriaSelect.change(function () {
                const categoriaId = $(this).val();
                
                // UX: Mostrar cargando
                equipoSelect.empty().prop('disabled', true);
                equipoSelect.append('<option value="">Buscando equipos...</option>');

                if (categoriaId) {
                    $.ajax({
                        url: '@Url.Action("GetEquiposPorCategoria", "Jgrxeqp")', 
                        type: 'GET',
                        data: { idCategoria: categoriaId },
                        dataType: 'json',
                        success: function (data) {
                            equipoSelect.empty().prop('disabled', false);
                            equipoSelect.append('<option value="">Seleccione un EQUIPO</option>');

                            if (data.length > 0) {
                                $.each(data, function (key, equipo) {
                                    equipoSelect.append('<option value="' + equipo.value + '">' + equipo.text + '</option>');
                                });
                            } else {
                                equipoSelect.append('<option value="">No hay equipos</option>');
                            }
                        },
                        error: function () {
                            equipoSelect.empty().prop('disabled', false);
                            equipoSelect.append('<option value="">Error de carga</option>');
                        }
                    });
                } else {
                    equipoSelect.empty().prop('disabled', false);
                    equipoSelect.append('<option value="">-- Primero elija Categoría --</option>');
                }
            });

            // LÓGICA CORREGIDA PARA PRESERVAR SELECCIÓN AL VOLVER DE ERROR (POST)
            // Si ya hay categoría seleccionada Y la lista de equipos está vacía (solo placeholder),
            // disparamos el cambio. Si el servidor ya llenó la lista (por el ViewModel), no hacemos nada.
            if (categoriaSelect.val() !== "") {
                 if (equipoSelect.children('option').length <= 1) {
                     categoriaSelect.trigger('change');
                 }
            }
            
            $.validator.unobtrusive.parse(document);
        });
    </script>
}