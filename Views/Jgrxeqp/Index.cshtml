@using ClubId.Data
@using Microsoft.AspNetCore.Mvc.Filters
@using Microsoft.EntityFrameworkCore

@model IEnumerable<ClubId.Models.ViewModels.JugadorPorEquipoViewModel>


@{
  ViewData["Title"] = "Jugadores";
}
<div class="d-flex justify-content-between align-items-center mb-3">
  <h2>Jugadores</h2>
  @* <a asp-action="Create" class="btn btn-primary">➕ Nuevo jugador</a> *@
</div>
<form method="get" class="row g-2 mb-3">
  <div class="col-sm-6 col-md-4">
    <input class="form-control" type="search" name="q" value="@(ViewBag.Query ?? "")"
      placeholder="Buscar por nombre, DNI o Carnet" />
  </div>
  <div class="col-auto">
    <button class="btn btn-outline-secondary" type="submit">Buscar</button>
  </div>
</form>
<div class="card shadow-sm mt-4">
  <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">
    <h4 class="mb-0 fw-bold">Listado de Jugadores Activos</h4>
    <a asp-action="Create" class="btn btn-primary btn-sm fw-bold">
      <i class="bi bi-plus-circle me-1"></i>  Nuevo jugador
    </a>
  </div>

  <div class="card-body p-0">
    <div class="table-responsive">
      <table class="table table-hover align-middle mb-0">
        <thead class="table-light">
          <tr>
            <th style="width: 35%;">Jugador / Identidad</th>
            <th style="width: 10%;" class="text-center">Estado</th>
            <th style="width: 15%;" class="text-center">Club / Categoría</th>
            <th style="width: 15%;" class="text-center">F. Recibo</th>
            <th style="width: 25%;" class="text-end">Acciones Rápidas</th>
          </tr>
        </thead>
        <tbody>
          @foreach (var p in Model)
          {
            <tr class="table-row-clickable" data-href="@Url.Action("Details", new { id = p.Idjugador })">

              <td>
                <div class="d-flex align-items-center">
                  <div class="flex-shrink-0 me-3">
                    @if (!string.IsNullOrWhiteSpace(p.Foto))
                    {
                      <img src="@p.Foto" class="rounded-circle border" alt="foto"
                        style="width: 50px; height: 50px; object-fit: cover;" />
                    }
                    else
                    {
                      <div
                        class="d-flex align-items-center justify-content-center bg-secondary-subtle rounded-circle border"
                        style="width: 50px; height: 50px;">
                        <i class="bi bi-person text-secondary fs-4"></i>
                      </div>
                    }
                  </div>
                  <div class="flex-grow-1">
                    <a asp-action="Details" asp-route-id="@p.Idjugador"
                      class="text-dark fw-bold text-decoration-none d-block">
                      @p.Apellido, @p.Nombre
                    </a>
                    <small class="text-muted">DNI: @p.Dni</small> |
                    <small class="text-info">N° Carnet: @p.Idjugador</small>
                  </div>
                </div>
              </td>

              <td class="text-center">
                @if (p.Activo)
                {
                  <span class="badge bg-success-subtle text-success border border-success-subtle fw-normal py-2 px-3">
                    HABILITADO
                  </span>
                }
                else
                {
                  <span class="badge bg-danger-subtle text-danger border border-danger-subtle fw-normal py-2 px-3">
                    SANCIONADO
                  </span>
                }
              </td>

              <td class="text-center">
                <span class="d-block badge rounded-pill bg-primary fw-bold mb-1">@p.NombreEq</span>
                <span class="d-block badge rounded-pill bg-secondary-subtle text-dark">@p.NombreCat</span>
              </td>

              <td class="text-center">
                <span class="text-nowrap">@p.FechaRecibo.ToShortDateString()</span>
              </td>

              <td class="text-end text-nowrap">
                <div class="btn-group" role="group">
                  <a asp-action="Edit" asp-route-id="@p.idjugadorxEquipo" title="Editar datos del jugador"
                    class="btn btn-sm btn-outline-primary">
                    <i class="bi bi-pencil-square"></i>EDITAR
                  </a>
                  <a asp-action="Pase" asp-route-id="@p.idjugadorxEquipo" title="Transferencia de Equipo/Categoría"
                    class="btn btn-sm btn-outline-info">
                    <i class="bi bi-arrow-left-right"></i> PASE
                  </a>
                  <a asp-controller="Sanciones" asp-action="HistorialJugador" asp-route-id="@p.Idjugador"
                    title="Ver Historial de Sanciones" class="btn btn-sm btn-outline-danger">
                    <i class="bi bi-shield-slash"></i>SANCIONES
                  </a>
                  <a asp-action="GenerarCarnet" asp-route-idpjxe="@p.idjugadorxEquipo" asp-route-idjugador="0"
                    title="Generar Carnet PDF" target="_blank" class="btn btn-sm btn-outline-secondary">
                    <i class="bi bi-file-earmark-pdf"></i>GENERAR PDF
                  </a>
                </div>
              </td>
            </tr>
          }
        </tbody>
      </table>
    </div>
  </div>
</div>

@section Scripts {
  <script>
    $(document).ready(function () {
      // ... Tu código JS existente ...

      // Lógica para hacer la fila entera clickeable para ver detalles
      $(".table-row-clickable").click(function () {
        var href = $(this).data("href");
        if (href) {
          // Prevenir la navegación si el clic fue en un botón/enlace dentro de la celda
          if (!$(event.target).closest('a, button').length) {
            window.location.href = href;
          }
        }
      });
    });
  </script>
}

