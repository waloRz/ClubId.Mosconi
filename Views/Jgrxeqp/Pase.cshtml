@using Microsoft.AspNetCore.Mvc.Filters
@using Microsoft.EntityFrameworkCore
@using ClubId.Data
@model ClubId.Models.ViewModels.JugadorPorEquipoViewModel

@{
  ViewData["Title"] = "Pase jugador";
}

<h2>Tranferencia jugador</h2>
<form asp-action="Pase" method="post" enctype="multipart/form-data" class="mt-3">
  <input type="hidden" asp-for="idjugadorxEquipo" />
 
<div class="row g-3">
  <div class="col-md-6">
    <label asp-for="Nombre" class="form-label"></label>
    <input asp-for="Nombre" class="form-control" readonly/>
    <span asp-validation-for="Nombre" class="text-danger"></span>
  </div>
  <div class="col-md-6">
    <label asp-for="Apellido" class="form-label"></label>
    <input asp-for="Apellido" class="form-control" readonly/>
    <span asp-validation-for="Apellido" class="text-danger"></span>
  </div>
<div class="col-md-3">
    <label asp-for="Dni" class="form-label"></label>
    
    @* MODIFICADO: Agregamos id, oninput y maxlength *@
    <input asp-for="Dni" class="form-control" id="DniInput" 
           oninput="formatAndValidateDni(this)" maxlength="10" 
           placeholder="XX.XXX.XXX" />
           
    <span asp-validation-for="Dni" class="text-danger"></span>
</div>
  <div class="col-md-4">
    <label asp-for="FechaNac" class="form-label">Fecha Nacimiento</label>
    <input asp-for="FechaNac" class="form-control" type="date" readonly/>
  </div>
  <div class="col-md-4">
    <label asp-for="FechaRecibo" class="form-label">Fecha del Pase</label>
    <input asp-for="FechaRecibo" class="form-control" type="date" />
  </div>
     <div class="form-group col-md-4">
        <label asp-for="IdCategoria" class="control-label">Categoría</label>
        <select asp-for="IdCategoria" class="form-control" asp-items="@Model.ListaCategoria">
            <option value="@Model.NombreCat">Seleccione una CATEGORIA</option>
        </select>
        <span asp-validation-for="IdCategoria" class="text-danger"></span>
    </div>
  <div class="form-group col-md-4">
        <label asp-for="IdEquipo" class="control-label">Equipo</label>
        <select asp-for="IdEquipo" class="form-control" asp-items="@Model.ListaEquipos">
            <option value="@Model.NombreEq">Seleccione un EQUIPO</option>
        </select>
        <span asp-validation-for="IdEquipo" class="text-danger"></span>     
    </div>

  <div class="col-md-3 form-check mt-4">
    <input asp-for="Activo" class="form-check-input" />
    <label asp-for="Activo" class="form-check-label"></label>
  </div>
  <div class="col-md-8">
    <label class="form-label">Foto</label>
    <input type="file" value="@Model.Foto"  name="photo" class="form-control" />
  </div>
   <div class="col-md-4">
    @if (!string.IsNullOrWhiteSpace(@Model.Foto))
    { <img src="@Model.Foto" class="img-thumbnail" alt="foto" style="max-width: 300px; max-height: 300px; object-fit: cover;" /> }
    else
    { <div class="border rounded p-5 text-center text-muted">Sin foto</div> }
  </div>
</div>

  <div class="mt-3">
    <button class="btn btn-primary" type="submit">Guardar cambios</button>
    <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
  </div>
</form>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}

    @* <script src="~/lib/jquery/dist/jquery.min.js"></script>  *@
    @* <script src="https://ajax.googleapis.com/ajax/libs/jquery/3.7.1/jquery.min.js"></script> *@
     @* Asegúrate de que jQuery esté cargado *@
    
    <script>
        // Función para aplicar el formato del DNI (mantener tu código original)
        @* function formatAndValidateDni(input) {
            // ... (Tu lógica de formato de DNI aquí) ...
            let dniValue = input.value.replace(/\D/g, '');
            let formattedDni = '';
            
            if (dniValue.length > 0) {
