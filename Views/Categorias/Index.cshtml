@model IEnumerable<CategoriaViewModel>

@{
    ViewData["Title"] = "Gestión de Categorías";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Listado de Categorías</h2>
        <a asp-action="Create" class="btn btn-primary btn-lg shadow-sm">
            <i class="bi bi-plus-lg"></i>  Nueva Categoría
        </a>
    </div>

    <table class="table table-striped table-hover align-middle" id="tablaCategorias">
        <thead class="table-dark">
            <tr>
                <th style="width: 50px">ID</th>
                <th>Nombre</th>
                <th>Estado</th>
                <th class="text-end" style="width: 150px;">Acciones</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td  align="center">@item.IdCategoria</td>
                    <td class="fw-bold ">@item.NombreCat</td>
                    <td>                      
                        @if (item.EstadoCat) 
                        {
                            <span class="badge bg-success">Activa</span>
                        }
                        else
                        {
                            <span class="badge bg-danger">Inactiva</span>
                        }
                    </td>
                    <td class="text-end">
                        <a asp-action="Edit" asp-route-id="@item.IdCategoria" class="btn btn-warning btn-sm" title="Editar">
                            <i class="bi bi-pencil"></i> Editar
                        </a>
                        @* <a asp-action="Delete" asp-route-id="@item.IdCategoria" class="btn btn-danger btn-sm" title="Eliminar">
                            <i class="bi bi-trash"></i> Eliminar
                        </a> *@
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@section Scripts {
    @* <script src="~/lib/jquery/dist/jquery.min.js"></script>  *@
    
    <link rel="stylesheet" type="text/css" href="https://cdn.datatables.net/v/bs5/dt-1.13.4/datatables.min.css"/>
    <script type="text/javascript" src="https://cdn.datatables.net/v/bs5/dt-1.13.4/datatables.min.js"></script>

    <script>
        $(document).ready(function () {
            // Inicializar DataTables en tu tabla con id="tablaCategorias"
            $('#tablaCategorias').DataTable({
                // Configuración para español
                language: {
                    url: 'https://cdn.datatables.net/plug-ins/1.13.4/i18n/es-ES.json'
                },
                // Configurar las opciones de cantidad de registros a visualizar
                lengthMenu: [
                    [5, 10, 25, 50, -1],
                    [5, 10, 25, 50, "Todos"] // Texto para mostrar en el dropdown
                ],
                // Ordenar por la columna 1 (Nombre) por defecto
                order: [[1, 'asc']], 
                
                // Habilitar la búsqueda (por defecto es true)
                searching: true,
                
                // Habilitar la paginación y el cambio de cantidad de registros
                paging: true,
                lengthChange: true
            });
        });
    </script>
}