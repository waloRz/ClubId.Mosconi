@model CategoriaViewModel

@{
    ViewData["Title"] = "Modificar Categoría";
}

<h3>Modificar Categoría</h3>

<div class="row">
    <div class="col-md-4">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            
            <input type="hidden" asp-for="IdCategoria" />

            <div class="form-group mb-3">
                <label asp-for="NombreCat" class="control-label"></label>
                <input asp-for="NombreCat" class="form-control" />
                <span asp-validation-for="NombreCat" class="text-danger"></span>
            </div>
            <div class="form-group form-check mb-3">
                <input class="form-check-input" type="checkbox" asp-for="EstadoCat" id="EstadoCat" />
                
                <label class="form-check-label" for="EstadoCat">
                    @Html.DisplayNameFor(model => model.EstadoCat)
                </label>
            </div>
            <div class="form-group">
                <input type="submit" value="Guardar Cambios" class="btn btn-warning" />
                <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}