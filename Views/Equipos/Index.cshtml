@using ClubId.Data
@using Microsoft.AspNetCore.Mvc.Filters
@using Microsoft.EntityFrameworkCore
@using ClubId.Models.ViewModels
@model IEnumerable<ClubId.Models.ViewModels.EquipoViewModel>

@{ ViewData["Title"] = "Equipos"; } 

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>Listado de Equipos</h2>
        <a asp-action="Create" class="btn btn-success"><i class="bi bi-plus-lg"></i> Nuevo Equipo</a>
    </div>

    <table class="table table-striped table-hover align-middle" id="tablaEquipos">
        <thead class="table-dark">
            <tr>
                <th style="width: 80px;">Escudo</th>
                <th>Nombre</th>
                <th>Categoría</th>
                <th>Delegado</th>
                <th>Estado</th>
                <th class="text-end">Acciones</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model) {
                <tr>
                    <td>
                        @if (!string.IsNullOrEmpty(item.FotoEq))
                        {
                            <img src="~/imagenes/equipos/@item.FotoEq" class="border border-light" style="width: 65px; height: 70px; object-fit: contain;" />
                        }
                        else
                        {
                            <i class="bi bi-shield-shaded text-secondary" style="font-size: 2rem;"></i>
                        }
                    </td>
                    <td class="fw-bold">@item.NombreEq</td>
                    <td>
                        <span class="badge bg-info text-dark fs-6">
                            @Html.DisplayFor(modelItem => item.NombreCategoria)
                        </span>
                    </td>
                    <td>
                        <div>@item.Delegado</div>
                        <small class="text-muted"><i class="bi bi-whatsapp"></i> @item.Celular</small>
                    </td>
                    <td>
                        @if (item.Estado)
                        {
                            <span class="badge bg-success">Activo</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">Inactivo</span>
                        }
                    </td>
                    <td class="text-end">
                        <a asp-action="Edit" asp-route-id="@item.IdEquipo" class="btn btn-warning btn-sm" title="Editar">Editar<i class="bi bi-pencil"></i></a>
                        @* <a asp-action="Delete" asp-route-id="@item.IdEquipo" class="btn btn-danger btn-sm" title="Eliminar">Eliminar<i class="bi bi-trash"></i></a> *@
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@section Scripts {
    @* <script src="~/lib/jquery/dist/jquery.min.js"></script>  *@
    
    <link rel="stylesheet" type="text/css" href="https://cdn.datatables.net/v/bs5/dt-1.13.4/datatables.min.css"/>
    <script type="text/javascript" src="https://cdn.datatables.net/v/bs5/dt-1.13.4/datatables.min.js"></script>

    <script>
        $(document).ready(function () {
            // Inicializar DataTables en tu tabla con id="tablaEquipos"
            $('#tablaEquipos').DataTable({
                // Configuración para español
                language: {                    
                    url: 'https://cdn.datatables.net/plug-ins/1.13.4/i18n/es-ES.json'
                },
                // Configurar las opciones de cantidad de registros a visualizar
                lengthMenu: [
                    [10, 25, 50, -1],
                    [10, 25, 50, "Todos"] // Texto para mostrar en el dropdown
                ],
                // Ordenar por la columna 1 (Nombre) por defecto
                order: [[1, 'asc']], 
                
                // Habilitar la búsqueda (por defecto es true, pero lo confirmamos)
                searching: true,
                
                // Habilitar la paginación
                paging: true,
                
                // Habilitar el cambio de cantidad de registros
                lengthChange: true
            });
        });
    </script>
}