@model IEnumerable<ClubId.Models.Player>

@{
  ViewData["Title"] = "Jugadores";
}
<div class="d-flex justify-content-between align-items-center mb-3">
  <h2>Jugadores</h2>
  <a asp-action="Create" class="btn btn-primary">➕ Nuevo jugador</a>
</div>

<form method="get" class="row g-2 mb-3">
  <div class="col-sm-6 col-md-4">
    <input class="form-control" type="search" name="q" value="@(ViewBag.Query ?? "")" placeholder="Buscar por nombre, DNI o equipo" />
  </div>
  <div class="col-auto">
    <button class="btn btn-outline-secondary" type="submit">Buscar</button>
  </div>
</form>

<table class="table table-striped align-middle">
  <thead>
    <tr>
      <th>Foto</th>
      <th>Apellido, Nombre</th>
      <th>DNI</th>
      <th>Equipo</th>
      <th>#</th>
      <th>Activo</th>
      <th></th>
    </tr>
  </thead>
  <tbody>
  @foreach (var p in Model)
  {
    <tr>
      <td>
        @if (!string.IsNullOrWhiteSpace(p.PhotoPath))
        { <img src="@p.PhotoPath" class="avatar" alt="foto" /> }
        else
        { <span class="badge bg-secondary">Sin foto</span> }
      </td>
      <td><a asp-action="Details" asp-route-id="@p.Id">@p.LastName, @p.FirstName</a></td>
      <td>@p.Dni</td>
      <td>@p.Team</td>
      <td>@p.Number</td>
      <td>@(p.Active ? "Sí" : "No")</td>
      <td class="text-nowrap">
        <a asp-action="Edit" asp-route-id="@p.Id" class="btn btn-sm btn-outline-primary">Editar</a>
        <a asp-action="Delete" asp-route-id="@p.Id" class="btn btn-sm btn-outline-danger">Eliminar</a>
        <a asp-action="CardPdf" asp-route-id="@p.Id" class="btn btn-sm btn-outline-secondary">🪪 PDF</a>
      </td>
    </tr>
  }
  </tbody>
</table>
