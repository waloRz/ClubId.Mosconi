@model ClubId.Models.Player
@{
  ViewData["Title"] = "Detalle";
}
<h2>Detalle</h2>
<div class="row g-3">
  <div class="col-md-3">
    @if (!string.IsNullOrWhiteSpace(Model.PhotoPath))
    { <img src="@Model.PhotoPath" class="img-thumbnail" alt="foto" /> }
    else
    { <div class="border rounded p-5 text-center text-muted">Sin foto</div> }
  </div>
  <div class="col-md-9">
    <dl class="row">
      <dt class="col-sm-3">Nombre</dt><dd class="col-sm-9">@Model.FirstName</dd>
      <dt class="col-sm-3">Apellido</dt><dd class="col-sm-9">@Model.LastName</dd>
      <dt class="col-sm-3">DNI</dt><dd class="col-sm-9">@Model.Dni</dd>
      <dt class="col-sm-3">Fecha nac.</dt><dd class="col-sm-9">@Model.BirthDate.ToString("dd/MM/yyyy")</dd>
      <dt class="col-sm-3">Equipo</dt><dd class="col-sm-9">@Model.Team</dd>
      <dt class="col-sm-3">#</dt><dd class="col-sm-9">@Model.Number</dd>
      <dt class="col-sm-3">Activo</dt><dd class="col-sm-9">@((Model.Active) ? "Sí" : "No")</dd>
    </dl>
    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">Editar</a>
    <a asp-action="CardPdf" asp-route-id="@Model.Id" class="btn btn-outline-secondary">Descargar carnet PDF</a>
    <a asp-action="Index" class="btn btn-secondary">Volver</a>
  </div>
</div>
