@model ClubId.Models.Player
@{
  ViewData["Title"] = "Editar jugador";
}

<h2>Editar jugador</h2>
<form asp-action="Edit" method="post" enctype="multipart/form-data" class="mt-3">
  <input type="hidden" asp-for="Id" />
 
<div class="row g-3">
  <div class="col-md-6">
    <label asp-for="FirstName" class="form-label"></label>
    <input asp-for="FirstName" class="form-control" />
    <span asp-validation-for="FirstName" class="text-danger"></span>
  </div>
  <div class="col-md-6">
    <label asp-for="LastName" class="form-label"></label>
    <input asp-for="LastName" class="form-control" />
    <span asp-validation-for="LastName" class="text-danger"></span>
  </div>
  <div class="col-md-6">
    <label asp-for="Dni" class="form-label"></label>
    <input asp-for="Dni" class="form-control" />
    <span asp-validation-for="Dni" class="text-danger"></span>
  </div>
  <div class="col-md-6">
    <label asp-for="BirthDate" class="form-label"></label>
    <input asp-for="BirthDate" class="form-control" type="date" />
  </div>
  <div class="col-md-6">
    <label asp-for="Team" class="form-label"></label>
    <input asp-for="Team" class="form-control" />
  </div>
  <div class="col-md-3">
    <label asp-for="Number" class="form-label"></label>
    <input asp-for="Number" class="form-control" />
  </div>
  <div class="col-md-3 form-check mt-4">
    <input asp-for="Active" class="form-check-input" />
    <label asp-for="Active" class="form-check-label"></label>
  </div>
  <div class="col-md-12">
    <label class="form-label">Foto</label>
    <input type="file" name="photo" class="form-control" />
  </div>
</div>

  <div class="mt-3">
    <button class="btn btn-primary" type="submit">Guardar cambios</button>
    <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
  </div>
</form>
