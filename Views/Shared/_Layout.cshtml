@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ClubId</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <style>
        /* ESTILOS MODERNOS EN LÍNEA (O muévelos a site.css) */
        
        body {
            font-family: 'Poppins', sans-serif;
            background-color: #f4f6f9; /* Fondo gris muy suave para resaltar tarjetas */
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }

        /* Navbar con Gradiente */
        .navbar-modern {
            /* Gradiente de Azul a Violeta (Muy moderno) */
            background: linear-gradient(135deg, #4158d0 0%, #c850c0 100%); 
            box-shadow: 0 4px 15px rgba(0,0,0,0.1); /* Sombra suave */
            padding-top: 1rem;
            padding-bottom: 1rem;
        }

        .navbar-brand {
            font-weight: 700;
            font-size: 1.5rem;
            letter-spacing: 0.5px;
            text-shadow: 1px 1px 2px rgba(0,0,0,0.2);
        }

        /* Efecto Hover en los enlaces */
        .nav-link {
            color: rgba(255,255,255,0.85) !important;
            font-weight: 500;
            transition: all 0.3s ease;
            border-radius: 50px;
            padding: 0.5rem 1rem !important;
        }

        .nav-link:hover {
            background-color: rgba(255, 255, 255, 0.2);
            color: #fff !important;
            transform: translateY(-2px); /* Pequeño salto al pasar el mouse */
        }

        .active-link {
            background-color: rgba(255, 255, 255, 0.3);
            color: #ffffff !important;
        }

        main {
            flex: 1; /* Esto empuja el footer hacia abajo */
        }

        .avatar {
            width: 80px;
            height: 80px;
            object-fit: cover;
            border-radius: 12px; /* Un poco más cuadrado pero suave */
            box-shadow: 0 4px 6px rgba(0,0,0,0.1);
        }

        /* Footer Moderno */
        .footer-modern {
            background-color: #fff;
            color: #6c757d;
            border-top: 1px solid #e9ecef;
            padding: 1.5rem 0;
            margin-top: 3rem;
            text-align: center;
        }
    </style>
</head>
<body>

    <nav class="navbar navbar-expand-lg navbar-dark navbar-modern sticky-top">
        <div class="container">
            <a class="navbar-brand" asp-controller="Jgrxeqp" asp-action="Index">
                <i class="bi bi-trophy-fill me-2"></i>ClubId
            </a>
            
            <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navbarNav">
                <div class="navbar-nav ms-auto"> <a class="nav-link mx-1" asp-controller="Jgrxeqp" asp-action="Index">
                        <i class="bi bi-people-fill me-1"></i> Jugadores
                    </a>
                    <a class="nav-link mx-1" asp-controller="Equipos" asp-action="Index">
                        <i class="bi bi-shield-shaded me-1"></i> Equipos
                    </a>
                    <a class="nav-link mx-1" asp-controller="Categorias" asp-action="Index">
                        <i class="bi bi-tags-fill me-1"></i> Categorías
                    </a>
                    <a class="nav-link mx-1 text-warning fw-bold" asp-controller="Sanciones" asp-action="Index">
                        <i class="bi bi-exclamation-triangle-fill me-1"></i> Sanciones
                    </a>
                </div>
            </div>
        </div>
    </nav>

    <main class="container py-4">
        @RenderBody()
    </main>

    <footer class="footer-modern">
        <div class="container">
            <p class="mb-0">
                &copy; 2025 <strong>ClubId</strong> - Gestión Deportiva Inteligente. 
                <span class="d-none d-sm-inline"> | <a href="#" class="text-decoration-none text-muted">Soporte</a></span>
            </p>
        </div>
    </footer>

    <script src="https://ajax.googleapis.com/ajax/libs/jquery/3.7.1/jquery.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)

    <script>
        $(document).ready(function () {
            // Obtener la URL actual
            var currentPath = window.location.pathname.toLowerCase();
            // Buscar el link que coincide y agregar clase 'active-link'
            $('.navbar-nav .nav-link').each(function () {
                var linkPath = $(this).attr('href').toLowerCase();
                if (currentPath === linkPath || (linkPath !== '/' && currentPath.indexOf(linkPath) !== -1)) {
                    $(this).addClass('active-link');
                }
            });
        });
    </script>
</body>
</html>